 function selectAmount(btn, amount) {
   document.querySelectorAll('.amount-btn').forEach(b => b.classList.remove('active'));
   btn.classList.add('active');
   selectedAmount = amount;
   document.getElementById('customAmount').value = '';
 }

 function setCustomAmount(val) {
   document.querySelectorAll('.amount-btn').forEach(b => b.classList.remove('active'));
   selectedAmount = val || '0';
 }

 function setFrequency(btn) {
   document.querySelectorAll('.freq-btn').forEach(b => b.classList.remove('active'));
   btn.classList.add('active');
   selectedFrequency = btn.dataset.freq;
 }

 function openDonateModal() {
   const amt = parseFloat(selectedAmount);
   if (!amt || amt < 1) { alert('Please select or enter a donation amount.'); return; }
   const freqLabels = { 'one-time': 'One-Time Donation', 'monthly': 'Monthly Donation', 'annually': 'Annual Donation' };
   document.getElementById('modalAmountDisplay').textContent = '$' + amt.toFixed(2).replace(/\.00$/, '');
   document.getElementById('modalFreqDisplay').textContent = freqLabels[selectedFrequency] || 'One-Time Donation';
   document.getElementById('donateModal').classList.add('open');
   document.body.style.overflow = 'hidden';
 }

 function closeDonateModal() {
   document.getElementById('donateModal').classList.remove('open');
   document.body.style.overflow = '';
   setTimeout(() => {
     document.getElementById('modalForm').style.display = '';
     document.getElementById('modalSuccess').style.display = 'none';
   }, 300);
 }

 function closeDonateModalOutside(e) {
   if (e.target === document.getElementById('donateModal')) closeDonateModal();
