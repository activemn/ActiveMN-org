 function saveContent() {
   const fields = document.querySelectorAll('.editable-field');
   fields.forEach((f, i) => savedContent[i] = f.innerHTML);
   // Persist to localStorage if available
   try { localStorage.setItem('activemn_content', JSON.stringify(savedContent)); } catch(e) {}
